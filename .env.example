# Producción / Neon (pooler): agrega pgbouncer + límites de pool para evitar P2024 en dev.
# Local con SQLite ya no aplica: el proyecto usa PostgreSQL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&pgbouncer=true&connection_limit=1&pool_timeout=30&connect_timeout=30"
ADMIN_PASSWORD="cambiar-en-produccion"
ADMIN_SESSION_SECRET="genera-un-secreto-largo-aleatorio"

# Formulario de contacto → notificación por correo (Resend)
CONTACT_TO_EMAIL="hola@sofiaciabattoni.com"
RESEND_API_KEY=""
# Remitente verificado en Resend (dominio sofiaciabattoni.com), ej:
# RESEND_FROM="Soulful Branding <hola@sofiaciabattoni.com>"
RESEND_FROM=""

# URL canónica del sitio (Open Graph, canonical). Producción: https://www.sofiaciabattoni.com
NEXT_PUBLIC_SITE_URL="https://www.sofiaciabattoni.com"

# Google Analytics 4 (público; opcional si usás el ID por defecto en código)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-7HMFH56SV0"

# Tras enviar el formulario de contacto: «Ir al calendario» (Llamada de claridad)
# Si no se define, el fallback está en src/lib/contact-calendar.ts
NEXT_PUBLIC_GOOGLE_CALENDAR_URL="https://calendar.app.google/oFCEDWf1ZdA5n8oT6"

# Solo en Vercel (uploads persistentes)
BLOB_READ_WRITE_TOKEN=""
